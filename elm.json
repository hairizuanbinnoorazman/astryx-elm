{
    "type": "package",
    "name": "hairizuanbinnoorazman/astryx-elm",
    "summary": "Accessible, Elm-native foundations for the Astryx design system",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "elm-version": "0.19.0 <= v < 0.20.0",
    "exposed-modules": [
        "Astryx.Accessibility",
        "Astryx.Badge",
        "Astryx.Banner",
        "Astryx.Button",
        "Astryx.Card",
        "Astryx.Center",
        "Astryx.Divider",
        "Astryx.Form.Checkbox",
        "Astryx.Form.Field",
        "Astryx.Form.FieldStatus",
        "Astryx.Form.Layout",
        "Astryx.Form.RadioGroup",
        "Astryx.Form.Select",
        "Astryx.Form.TextArea",
        "Astryx.Form.TextInput",
        "Astryx.Grid",
        "Astryx.Heading",
        "Astryx.Icon",
        "Astryx.Link",
        "Astryx.Progress",
        "Astryx.Size",
        "Astryx.Stack",
        "Astryx.Status",
        "Astryx.StatusDot",
        "Astryx.Spinner",
        "Astryx.Text",
        "Astryx.Theme"
